<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.collections.*?>

<VBox style="-fx-background-color: ffbf49;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.prodaja_vozila.ListaPostojecihKupacaKontroler">
   <children>
      <GridPane maxHeight="600.0" maxWidth="500.0" minHeight="600.0" minWidth="500.0" prefHeight="600.0" prefWidth="500.0">
        <columnConstraints>
          <ColumnConstraints />
            <ColumnConstraints hgrow="SOMETIMES" maxWidth="500.0" minWidth="500.0" prefWidth="500.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints maxHeight="50.0" minHeight="50.0" prefHeight="50.0" vgrow="SOMETIMES" />
          <RowConstraints maxHeight="500.0" minHeight="500.0" prefHeight="500.0" vgrow="SOMETIMES" />
          <RowConstraints maxHeight="50.0" minHeight="50.0" prefHeight="50.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <HBox prefHeight="50.0" prefWidth="490.0" style="-fx-background-color: ffff55;" GridPane.columnIndex="1">
               <children>
                  <Label text="Lista kupaca vozila" textAlignment="CENTER" textFill="#49b3ff">
                     <font>
                        <Font name="System Bold Italic" size="16.0" />
                     </font>
                     <padding>
                        <Insets left="160.0" top="10.0" />
                     </padding>
                  </Label>
               </children>
               <GridPane.margin>
                  <Insets bottom="3.0" left="8.0" right="8.0" top="3.0" />
               </GridPane.margin>
            </HBox>
            <HBox maxHeight="500.0" maxWidth="500.0" minHeight="500.0" minWidth="500.0" prefHeight="500.0" prefWidth="500.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
               <children>
                  <GridPane>
                    <columnConstraints>
                      <ColumnConstraints hgrow="SOMETIMES" maxWidth="490.0" minWidth="485.0" prefWidth="485.0" />
                    </columnConstraints>
                    <rowConstraints>
                      <RowConstraints maxHeight="50.0" minHeight="50.0" prefHeight="50.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                     <children>
                        <GridPane style="-fx-background-color: ffff55;">
                          <columnConstraints>
                            <ColumnConstraints hgrow="SOMETIMES" maxWidth="170.0" minWidth="485.0" prefWidth="170.0" />
                          </columnConstraints>
                          <rowConstraints>
                            <RowConstraints maxHeight="50.0" minHeight="50.0" prefHeight="50.0" vgrow="SOMETIMES" />
                          </rowConstraints>
                           <children>
                              <Label text="Odaberite kupca:">
                                 <font>
                                    <Font name="System Bold Italic" size="12.0" />
                                 </font>
                                 <GridPane.margin>
                                    <Insets left="180.0" />
                                 </GridPane.margin>
                              </Label>
                           </children>
                        </GridPane>
                        <ScrollPane prefHeight="200.0" prefWidth="200.0" GridPane.rowIndex="1">
                           <content>
                              <TableView fx:id="tabelaKupaca" prefHeight="438.0" prefWidth="483.0">
                                <columns>
                                  <TableColumn fx:id="idKolona" minWidth="80.0" prefWidth="75.0" text="ID" />
                                  <TableColumn fx:id="kategorijaKolona" minWidth="90.0" prefWidth="87.0" text="Kategorija" />
                                    <TableColumn fx:id="nazivKolona" minWidth="100.0" prefWidth="100.0" text="Naziv" />
                                    <TableColumn fx:id="adresaKolona" minWidth="90.0" prefWidth="90.0" text="Adresa" />
                                    <TableColumn fx:id="emailKolona" maxWidth="120.0" minWidth="120.0" prefWidth="120.0" text="E-mail" />
                                </columns>
                              </TableView>
                           </content>
                        </ScrollPane>
                     </children>
                     <HBox.margin>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                     </HBox.margin>
                  </GridPane>
               </children>
               <GridPane.margin>
                  <Insets bottom="3.0" left="3.0" right="3.0" top="3.0" />
               </GridPane.margin>
            </HBox>
            <HBox prefHeight="500.0" prefWidth="500.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
               <children>
                  <Button fx:id="Dugme" maxHeight="35.0" maxWidth="50.0" minHeight="35.0" minWidth="55.0" mnemonicParsing="false" onAction="#potvrdi" prefHeight="35.0" prefWidth="50.0" text="OK">
                     <HBox.margin>
                        <Insets left="190.0" />
                     </HBox.margin>
                  </Button>
                  <Button fx:id="cancelDugme" maxHeight="35.0" maxWidth="50.0" minHeight="35.0" minWidth="55.0" mnemonicParsing="false" onAction="#otkazi" prefHeight="35.0" prefWidth="55.0" text="Cancel">
                     <HBox.margin>
                        <Insets left="20.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
         </children>
      </GridPane>
   </children>
</VBox>
